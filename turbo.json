{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "outputs": [
        "dist/**",
        "build/**",
        "api/**",
        "public/build/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "dependsOn": ["^build"],
      "env": [
        "AUTH_PROVIDERS",
        "CARBON_EDITION",
        "CLOUDFLARE_TURNSTILE_SITE_KEY",
        "CLOUDFLARE_TURNSTILE_SECRET_KEY",
        "DOMAIN",
        "ERP_URL",
        "MES_URL",
        "NOVU_APPLICATION_ID",
        "NOVU_SECRET_KEY",
        "POSTHOG_API_HOST",
        "POSTHOG_PROJECT_PUBLIC_KEY",
        "RESEND_API_KEY",
        "RESEND_DOMAIN",
        "SLACK_BOT_TOKEN",
        "SESSION_SECRET",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_URL",
        "SUPABASE_DB_URL",
        "SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID",
        "SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET",
        "SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI",
        "SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID",
        "SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_SECRET",
        "SUPABASE_AUTH_EXTERNAL_AZURE_REDIRECT_URI",
        "TRIGGER_SECRET_KEY",
        "TRIGGER_API_URL",
        "TRIGGER_PROJECT_ID",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "GOOGLE_PLACES_API_KEY",
        "RATE_LIMIT"
      ]
    },
    "carbon#build": {
      "dependsOn": ["^build"],
      "outputs": ["api/index.js", "api/build/**", "public/build/**"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "db:start": {
      "outputs": []
    },
    "db:kill": {
      "outputs": []
    },
    "db:types": {
      "outputs": [],
      "cache": true
    },
    "db:init": {
      "outputs": []
    },
    "db:migrate": {
      "outputs": [],
      "cache": false
    },
    "db:push": {
      "outputs": []
    },
    "db:pull": {
      "outputs": []
    },
    "db:seed": {
      "outputs": [],
      "cache": false
    },
    "db:migrate:force": {
      "outputs": []
    },
    "setup": {
      "cache": false,
      "outputs": []
    },
    "typegen": {
      "cache": false,
      "outputs": []
    }
  }
}
